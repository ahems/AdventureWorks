              }
            },
            {
              "action": "read"
            },
            {
              "action": "update",
              "fields": {
                "exclude": ["BusinessEntityID", "rowguid", "ModifiedDate"]
              }
            },
            {
              "action": "delete"
            }
          ]
        }
      ],
      "relationships": {
        "emailAddresses": {
          "cardinality": "many",
          "target.entity": "EmailAddress",
          "source.fields": ["BusinessEntityID"],
          "target.fields": ["BusinessEntityID"]
