# Base image includes PowerShell 7 + Az PowerShell modules preinstalled
# (Good fit for automation containers that need Az cmdlets)
FROM mcr.microsoft.com/azure-powershell:latest

# Optional: install OS security updates (recommended by MS docs for these images)
# and tools that sometimes help with troubleshooting / TLS / zip, etc.
RUN apt-get update && apt-get upgrade -y \
    && apt-get install -y --no-install-recommends \
       ca-certificates curl unzip \
    && rm -rf /var/lib/apt/lists/*

# Set a working directory inside the container
WORKDIR /app

# Copy your job script + assets into the image
# Note: Paths are relative to the seed-job folder (build context)
COPY seed-database.ps1 /app/seed-database.ps1

# Copy SQL scripts
COPY sql/ /app/sql/
# Copy images
COPY images/ /app/images/

# Environment variables (set these at job creation time too; these are defaults/fallbacks)
ENV AZURE_RESOURCE_GROUP=""
ENV SQL_SERVER_NAME=""
ENV SQL_DATABASE_NAME="todo"
ENV USER_MANAGED_IDENTITY_NAME=""
ENV TENANT_ID=""

# Run the database seeding script
ENTRYPOINT ["pwsh", "-NoLogo", "-NoProfile", "-File", "/app/seed-database.ps1"]