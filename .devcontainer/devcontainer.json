{
  "name": "AdventureWorks",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "features": {
    "ghcr.io/devcontainers/features/azure-cli:1": {
      "version": "latest"
    },
    "ghcr.io/devcontainers/features/git:1": {
      "version": "latest",
      "lfs": true
    },
    "ghcr.io/azure/azure-dev/azd:latest": {},
    "ghcr.io/devcontainers/features/powershell:1": {
      "version": "latest"
    },
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "version": "latest"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-azuretools.vscode-bicep",
        "ms-vscode.powershell",
        "ms-dotnettools.csharp",
        "ms-dotnettools.csdevkit",
        "ms-azuretools.vscode-azurefunctions",
        "ms-vscode.vscode-node-azure-pack",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "bradlc.vscode-tailwindcss"
      ],
      "settings": {
        // PowerShell settings
        "powershell.powerShellAdditionalExePaths": {
          "PowerShell (x64)": "/usr/bin/pwsh"
        },
        "powershell.powerShellDefaultVersion": "PowerShell (x64)",
        "powershell.enableStartUpBanner": false,

        // .NET settings
        "dotnet.defaultSolution": "AdventureWorks.sln",

        // Format settings
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "[csharp]": {
          "editor.defaultFormatter": "ms-dotnettools.csharp"
        }
      }
    }
  },
  "forwardPorts": [5000, 5173, 7071],
  "portsAttributes": {
    "5000": {
      "label": "DAB API",
      "onAutoForward": "notify"
    },
    "5173": {
      "label": "Vite Dev Server",
      "onAutoForward": "notify"
    },
    "7071": {
      "label": "Azure Functions",
      "onAutoForward": "notify"
    }
  },
  "postCreateCommand": "az bicep install && dotnet restore api-functions/api-functions.csproj && cd app && bun install",
  "hostRequirements": {
    "memory": "8gb"
  }
}
